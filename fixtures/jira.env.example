# Jira Tinh Van -- Server 8.3.3 (https://jira.tinhvan.com)

JIRA_BASE_URL=https://jira.tinhvan.com

# Logwork UI/API — chỉ Jira thật (mock/demo đã tắt)
# LOGWORK_QA_USERS=qa_user1,qa_user2
# LOGWORK_ADMIN_USERS=cfg_admin
# Quyền Logwork (env server) — KHÔNG liên quan Administrator / quản trị Jira:
#   admin  — cấu hình phạt, lễ, OT (+ mọi quyền QA)
#   qa     — đối soát team, golden, job nhắc
#   (mặc định trống → mọi user Jira hợp lệ = employee, chỉ xem cá nhân)
# LAN / công ty test (mở mạng nội bộ)
# LOGWORK_ALLOW_LAN=1          # CORS cho IP LAN (khi gọi API trực tiếp :8000)
# LOGWORK_UI_PORT=5173
# LOGWORK_API_PORT=8000
# Chạy: .\logwork\scripts\run_lan.ps1

# LOGWORK_DATA_DIR=d:\TINHVAN\HVKHQS-AI\logwork\fixtures\live

# Scheduler 17h T4: JIRA_USERNAME + JIRA_API_TOKEN (hoặc trigger QA)
# JIRA_USERNAME=qa_bot
# JIRA_API_TOKEN=...

# Lọc project (mặc định: tất cả project)
# LOGWORK_PROJECT_KEYS=HVKHQS,TVE2516TK
# LOGWORK_PROJECT_KEYS=*

# Roster QA: fixtures/live/employees.csv
# LOGWORK_ROSTER_ONLY=1
# LOGWORK_TEAM=QA
# LOGWORK_CENTER=HVKHQS

# Email nhắc NV vi phạm (job 17h T4 + admin trigger)
# LOGWORK_SMTP_HOST=smtp.tinhvan.vn
# LOGWORK_SMTP_PORT=587
# LOGWORK_SMTP_USER=logwork@tinhvan.vn
# LOGWORK_SMTP_PASSWORD=...
# LOGWORK_EMAIL_FROM=logwork@tinhvan.vn
# LOGWORK_EMAIL_FROM_NAME=Logwork QA Audit
# LOGWORK_SMTP_TLS=1
# LOGWORK_EMAIL_GUESS=0
# LOGWORK_EMAIL_DOMAIN=tinhvan.vn
